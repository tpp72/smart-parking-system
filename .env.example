APP_NAME=Smart-Parking
APP_ENV=local
APP_KEY=                        # [ต้องทำ] รัน: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───
# [ต้องทำ] สร้าง database ชื่อ smart-parking-system แล้วแก้ password ด้านล่าง
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smart-parking-system
DB_USERNAME=postgres
DB_PASSWORD=                    # [ต้องทำ] ใส่ password PostgreSQL ของเครื่องตัวเอง

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# ─── Mail ───
# [ต้องทำ] ถ้าต้องการส่งเมล ให้แก้ค่าด้านล่าง (ไม่ได้ใช้ก็ปล่อยไว้แบบนี้)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=                  # [ต้องทำ] Gmail ที่ใช้ส่งเมล
MAIL_PASSWORD=                  # [ต้องทำ] App Password (ไม่ใช่ password Gmail ปกติ)
MAIL_FROM_ADDRESS="your@email.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── AI Car Scan (Gemini Vision) ───
# [ต้องทำ] ขอ API Key ฟรีได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=                 # [ต้องทำ] ใส่ Gemini API Key
CARSCAN_MODEL=gemini-2.5-flash  # (optional) เปลี่ยน model ได้ที่นี่
# โมเดล:
# gemini-2.5-flash          → เร็ว ฟรี 500 req/วัน  ✅ แนะนำ
# gemini-2.0-flash          → ฟรี 1,500 req/วัน (ความแม่นน้อยกว่า 2.5)
# gemini-2.0-flash-lite     → เร็วที่สุด ฟรี 1,500 req/วัน
# gemini-1.5-flash          → ฟรี 1,500 req/วัน รองรับภาษาไทยดี
# gemini-1.5-pro            → ฟรี 50 req/วัน แม่นที่สุด แต่ช้า
